<Window x:Class="Tabu.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Tabu.UI.Controls"
        Title="Tabu Settings"
        Icon="pack://application:,,,/Assets/tabu.ico"
        Width="380" Height="820"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Border x:Name="SettingsRoot"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Cursor="Arrow">
                <Grid Height="38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center" Margin="14,0,8,0" />
                    <TextBlock Grid.Column="1" Text="{DynamicResource Settings_Title}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Style="{DynamicResource CloseWindowButtonStyle}"
                            Content="&#xE8BB;"
                            Click="Close_Click" Width="38" Height="38" />
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0">
                <StackPanel Margin="16,16,16,8">

                    <!-- ============== Card: Bar layout ============== -->
                    <Border Style="{DynamicResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Settings_Group_BarLayout}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,20" />

                            <!-- Bar placement -->
                            <TextBlock Text="{DynamicResource Settings_BarDisplay}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="PrimaryBarRadio" Grid.Column="0" GroupName="BarPlacement"
                                             IsChecked="True" Checked="BarPlacement_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_PrimaryOnly}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="AllBarsRadio" Grid.Column="1" GroupName="BarPlacement"
                                             Checked="BarPlacement_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_AllMonitors}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Window detection -->
                            <TextBlock Text="{DynamicResource Settings_WindowDetection}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="DetectAllRadio" Grid.Column="0" GroupName="DetectionMode"
                                             IsChecked="True" Checked="DetectionMode_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_AllWindows}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="DetectSameScreenRadio" Grid.Column="1" GroupName="DetectionMode"
                                             Checked="DetectionMode_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_SameScreen}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Bar size -->
                            <TextBlock Text="{DynamicResource Settings_BarSize}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="BarSizeSmallRadio" Grid.Column="0" GroupName="BarSize"
                                             IsChecked="True" Checked="BarSize_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_BarSizeSmall}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="BarSizeMediumRadio" Grid.Column="1" GroupName="BarSize"
                                             Checked="BarSize_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_BarSizeMedium}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="BarSizeLargeRadio" Grid.Column="2" GroupName="BarSize"
                                             Checked="BarSize_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_BarSizeLarge}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Bar visibility -->
                            <TextBlock Text="{DynamicResource Settings_BarVisibility}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="BarAlwaysVisibleRadio" Grid.Column="0" GroupName="BarVisibility"
                                             IsChecked="True" Checked="BarVisibility_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_AlwaysVisible}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="BarAutoHideRadio" Grid.Column="1" GroupName="BarVisibility"
                                             Checked="BarVisibility_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_AutoHide}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============== Card: Appearance ============== -->
                    <Border Style="{DynamicResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Settings_Group_Appearance}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,20" />

                            <!-- Background blur (must come first; locks theme + opacity) -->
                            <TextBlock Text="{DynamicResource Settings_Blur}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="BlurDisabledRadio" Grid.Column="0" GroupName="Blur"
                                             IsChecked="True" Checked="Blur_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_BlurDisable}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="BlurEnabledRadio" Grid.Column="1" GroupName="Blur"
                                             Checked="Blur_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_BlurEnable}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Theme (lockable) -->
                            <Grid x:Name="ThemeSection" Margin="0,0,0,20">
                                <StackPanel x:Name="ThemeContent">
                                    <TextBlock Text="{DynamicResource Settings_Theme}" FontSize="11" FontWeight="Medium"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <RadioButton x:Name="ThemeSystemRadio" Grid.Column="0" GroupName="Theme"
                                                     IsChecked="True" Checked="Theme_Changed"
                                                     Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Settings_ThemeSystem}" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </RadioButton>
                                        <RadioButton x:Name="ThemeDarkRadio" Grid.Column="1" GroupName="Theme"
                                                     Checked="Theme_Changed"
                                                     Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource Settings_ThemeDark}" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </RadioButton>
                                        <RadioButton x:Name="ThemeLightRadio" Grid.Column="2" GroupName="Theme"
                                                     Checked="Theme_Changed"
                                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                            <TextBlock Text="{DynamicResource Settings_ThemeLight}" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </RadioButton>
                                    </Grid>
                                </StackPanel>
                                <!-- Click-blocker overlay shown when blur is on -->
                                <Border x:Name="ThemeLockOverlay" Background="Transparent" Visibility="Collapsed"
                                        MouseLeftButtonDown="LockedSection_Click" Cursor="No" />
                            </Grid>

                            <!-- Bar opacity (lockable) -->
                            <Grid x:Name="OpacitySection" Margin="0,0,0,20">
                                <StackPanel x:Name="OpacityContent">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource Settings_BarOpacity}" FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                        <TextBlock x:Name="OpacityValueText" Grid.Column="1" FontSize="11"
                                                   Foreground="{DynamicResource MutedTextBrush}" Text="100%" />
                                    </Grid>
                                    <Slider x:Name="OpacitySlider"
                                            Minimum="30" Maximum="100" Value="100"
                                            IsSnapToTickEnabled="True" TickFrequency="1"
                                            ValueChanged="Opacity_Changed" />
                                </StackPanel>
                                <Border x:Name="OpacityLockOverlay" Background="Transparent" Visibility="Collapsed"
                                        MouseLeftButtonDown="LockedSection_Click" Cursor="No" />
                            </Grid>

                            <!-- Accent color: swatch button opens an HSV color wheel popup. -->
                            <TextBlock Text="{DynamicResource Settings_AccentColor}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="AccentColorSwatchButton"
                                        Width="28" Height="28" Padding="0"
                                        Cursor="Hand"
                                        Click="AccentColorSwatch_Click"
                                        Margin="0,0,8,0"
                                        BorderThickness="0" Background="Transparent">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="6"
                                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <Ellipse Width="14" Height="14"
                                                         Fill="{DynamicResource AccentBrush}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBox x:Name="AccentColorBox" Grid.Column="1"
                                         Height="28" Padding="8,4" FontSize="11"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource TertiaryBackgroundBrush}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                         TextChanged="AccentColor_TextChanged"
                                         ToolTip="#RRGGBB" />
                                <Button Grid.Column="2" Content="{DynamicResource Settings_AccentColorReset}"
                                        Click="AccentColorReset_Click"
                                        Margin="8,0,0,0" Padding="10,4" FontSize="11"
                                        Background="Transparent"
                                        Foreground="{DynamicResource MutedTextBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                            </Grid>

                            <Popup x:Name="AccentColorPopup" StaysOpen="False"
                                   Placement="Bottom" PlacementTarget="{Binding ElementName=AccentColorSwatchButton}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12"
                                        Margin="0,6,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.45" Color="Black" />
                                    </Border.Effect>
                                    <controls:ColorWheelPicker x:Name="AccentColorWheel"
                                                               SelectedColorChanged="AccentColorWheel_SelectedColorChanged" />
                                </Border>
                            </Popup>

                            <!-- Branding -->
                            <TextBlock Text="{DynamicResource Settings_Branding}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="BrandingVisibleRadio" Grid.Column="0" GroupName="Branding"
                                             IsChecked="True" Checked="Branding_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_ShowLogo}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="BrandingHiddenRadio" Grid.Column="1" GroupName="Branding"
                                             Checked="Branding_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_HideLogo}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ============== Card: Tabs ============== -->
                    <Border Style="{DynamicResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Settings_Group_Tabs}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,20" />

                            <!-- Tab width -->
                            <TextBlock Text="{DynamicResource Settings_TabWidth}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="TabFullWidthRadio" Grid.Column="0" GroupName="TabWidth"
                                             IsChecked="True" Checked="TabWidth_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_FullWidth}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="TabFixedWidthRadio" Grid.Column="1" GroupName="TabWidth"
                                             Checked="TabWidth_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_FixedWidth}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Clock -->
                            <TextBlock Text="{DynamicResource Settings_Clock}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="ClockVisibleRadio" Grid.Column="0" GroupName="Clock"
                                             IsChecked="True" Checked="Clock_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_ShowClock}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="ClockHiddenRadio" Grid.Column="1" GroupName="Clock"
                                             Checked="Clock_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_HideClock}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Clock size (only relevant when the clock is visible) -->
                            <StackPanel x:Name="ClockSizePanel">
                                <TextBlock Text="{DynamicResource Settings_ClockSize}" FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="ClockSizeSmallRadio" Grid.Column="0" GroupName="ClockSize"
                                                 IsChecked="True" Checked="ClockSize_Changed"
                                                 Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                        <TextBlock Text="{DynamicResource Settings_BarSizeSmall}" FontSize="11"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </RadioButton>
                                    <RadioButton x:Name="ClockSizeMediumRadio" Grid.Column="1" GroupName="ClockSize"
                                                 Checked="ClockSize_Changed"
                                                 Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                        <TextBlock Text="{DynamicResource Settings_BarSizeMedium}" FontSize="11"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </RadioButton>
                                    <RadioButton x:Name="ClockSizeLargeRadio" Grid.Column="2" GroupName="ClockSize"
                                                 Checked="ClockSize_Changed"
                                                 Foreground="{DynamicResource PrimaryTextBrush}">
                                        <TextBlock Text="{DynamicResource Settings_BarSizeLarge}" FontSize="11"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </RadioButton>
                                </Grid>
                            </StackPanel>

                            <!-- Notification badges -->
                            <TextBlock Text="{DynamicResource Settings_Notifications}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,20,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="NotificationsEnabledRadio" Grid.Column="0" GroupName="Notifications"
                                             IsChecked="True" Checked="Notifications_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_NotificationsEnable}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="NotificationsDisabledRadio" Grid.Column="1" GroupName="Notifications"
                                             Checked="Notifications_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_NotificationsDisable}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Notification dot size + color (only when enabled) -->
                            <StackPanel x:Name="NotificationDotPanel" Margin="0,16,0,0">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{DynamicResource Settings_NotificationDotSize}" FontSize="11" FontWeight="Medium"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock x:Name="NotificationDotSizeValueText" Grid.Column="1" FontSize="11"
                                               Foreground="{DynamicResource MutedTextBrush}" Text="7 px" />
                                </Grid>
                                <Slider x:Name="NotificationDotSizeSlider"
                                        Minimum="4" Maximum="12" Value="7"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="NotificationDotSize_Changed" />

                                <TextBlock Text="{DynamicResource Settings_NotificationDotColor}" FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,16,0,8" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Swatch acts as a button that opens the wheel popup. -->
                                    <Button Grid.Column="0" x:Name="DotColorSwatchButton"
                                            Width="28" Height="28" Padding="0"
                                            Cursor="Hand"
                                            Click="DotColorSwatch_Click"
                                            Margin="0,0,8,0"
                                            BorderThickness="0" Background="Transparent">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="6"
                                                        Background="{DynamicResource TertiaryBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                    <Ellipse x:Name="NotificationDotPreview" Width="14" Height="14"
                                                             Fill="{DynamicResource NotificationDotBrush}" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBox x:Name="NotificationDotColorBox" Grid.Column="1"
                                             Height="28" Padding="8,4" FontSize="11"
                                             VerticalContentAlignment="Center"
                                             Background="{DynamicResource TertiaryBackgroundBrush}"
                                             Foreground="{DynamicResource PrimaryTextBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                             TextChanged="NotificationDotColor_TextChanged"
                                             ToolTip="#RRGGBB" />
                                    <Button Grid.Column="2" Content="{DynamicResource Settings_NotificationDotColorReset}"
                                            Click="NotificationDotColorReset_Click"
                                            Margin="8,0,0,0" Padding="10,4" FontSize="11"
                                            Background="Transparent"
                                            Foreground="{DynamicResource MutedTextBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                                </Grid>

                                <!-- Color wheel popup, anchored to the swatch button. -->
                                <Popup x:Name="DotColorPopup" StaysOpen="False"
                                       Placement="Bottom" PlacementTarget="{Binding ElementName=DotColorSwatchButton}"
                                       AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="12"
                                            Margin="0,6,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.45" Color="Black" />
                                        </Border.Effect>
                                        <controls:ColorWheelPicker x:Name="DotColorWheel"
                                                                   SelectedColorChanged="DotColorWheel_SelectedColorChanged" />
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <!-- Active tab tint (color + opacity) -->
                            <TextBlock Text="{DynamicResource Settings_ActiveTab}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,20,0,8" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="ActiveTabColorSwatchButton"
                                        Width="28" Height="28" Padding="0"
                                        Cursor="Hand"
                                        Click="ActiveTabColorSwatch_Click"
                                        Margin="0,0,8,0"
                                        BorderThickness="0" Background="Transparent">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="6"
                                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <Rectangle Width="18" Height="18" RadiusX="4" RadiusY="4"
                                                           Fill="{DynamicResource ActiveTabBackgroundBrush}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBox x:Name="ActiveTabColorBox" Grid.Column="1"
                                         Height="28" Padding="8,4" FontSize="11"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource TertiaryBackgroundBrush}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                         TextChanged="ActiveTabColor_TextChanged"
                                         ToolTip="#RRGGBB" />
                                <Button Grid.Column="2" Content="{DynamicResource Settings_NotificationDotColorReset}"
                                        Click="ActiveTabColorReset_Click"
                                        Margin="8,0,0,0" Padding="10,4" FontSize="11"
                                        Background="Transparent"
                                        Foreground="{DynamicResource MutedTextBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                            </Grid>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_ActiveTabOpacity}" FontSize="11" FontWeight="Medium"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock x:Name="ActiveTabOpacityValueText" Grid.Column="1" FontSize="11"
                                           Foreground="{DynamicResource MutedTextBrush}" Text="100%" />
                            </Grid>
                            <Slider x:Name="ActiveTabOpacitySlider"
                                    Minimum="0" Maximum="100" Value="100"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="ActiveTabOpacity_Changed" />

                            <Popup x:Name="ActiveTabColorPopup" StaysOpen="False"
                                   Placement="Bottom" PlacementTarget="{Binding ElementName=ActiveTabColorSwatchButton}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12"
                                        Margin="0,6,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.45" Color="Black" />
                                    </Border.Effect>
                                    <controls:ColorWheelPicker x:Name="ActiveTabColorWheel"
                                                               SelectedColorChanged="ActiveTabColorWheel_SelectedColorChanged" />
                                </Border>
                            </Popup>
                        </StackPanel>
                    </Border>

                    <!-- ============== Card: System ============== -->
                    <Border Style="{DynamicResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Settings_Group_System}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,20" />

                            <!-- Language -->
                            <TextBlock Text="{DynamicResource Settings_Language}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <ComboBox x:Name="LanguageCombo" SelectionChanged="Language_Changed"
                                      FontSize="11" Height="28" Padding="8,4" Margin="0,0,0,20" />

                            <!-- Startup -->
                            <TextBlock Text="{DynamicResource Settings_Startup}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="StartupEnabledRadio" Grid.Column="0" GroupName="Startup"
                                             Checked="Startup_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_StartAtLogin}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="StartupDisabledRadio" Grid.Column="1" GroupName="Startup"
                                             IsChecked="True" Checked="Startup_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_DontStartAtLogin}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>

                            <!-- Updates -->
                            <TextBlock Text="{DynamicResource Settings_Updates}" FontSize="11" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <RadioButton x:Name="AutoUpdatesEnabledRadio" Grid.Column="0" GroupName="AutoUpdates"
                                             IsChecked="True" Checked="AutoUpdates_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,8,0">
                                    <TextBlock Text="{DynamicResource Settings_AutoUpdatesEnable}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                                <RadioButton x:Name="AutoUpdatesDisabledRadio" Grid.Column="1" GroupName="AutoUpdates"
                                             Checked="AutoUpdates_Changed"
                                             Foreground="{DynamicResource PrimaryTextBrush}">
                                    <TextBlock Text="{DynamicResource Settings_AutoUpdatesDisable}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </RadioButton>
                            </Grid>
                            <Button x:Name="CheckUpdatesNowButton"
                                    Content="{DynamicResource Settings_CheckUpdatesNow}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="CheckUpdatesNow_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,6" />
                            <Button x:Name="ResetSettingsButton"
                                    Content="{DynamicResource Settings_Reset}"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="ResetSettings_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="12,6"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer with Done button -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,6,6"
                    Padding="16,10">
                <Button Content="{DynamicResource Settings_Done}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Close_Click"
                        HorizontalAlignment="Right"
                        Padding="20,6" />
            </Border>

            <!-- Toast banner overlay (Grid.RowSpan covers the full window) -->
            <Border x:Name="ToastBanner"
                    Grid.Row="0" Grid.RowSpan="3"
                    Style="{DynamicResource ToastBannerStyle}"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,72"
                    MinWidth="240" MaxWidth="320"
                    Opacity="0"
                    IsHitTestVisible="False"
                    RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTranslate" Y="20" />
                </Border.RenderTransform>
                <TextBlock x:Name="ToastText" FontSize="11"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</Window>