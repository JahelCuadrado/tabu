<Window x:Class="Tabu.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tabu Settings"
        Icon="pack://application:,,,/Assets/tabu.ico"
        Width="340" Height="1080"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Border x:Name="SettingsRoot"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="6"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    Cursor="Arrow">
                <Grid Height="34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center" Margin="12,0,8,0" />
                    <TextBlock Grid.Column="1" Text="{DynamicResource Settings_Title}" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Style="{DynamicResource CloseWindowButtonStyle}"
                            Content="&#xE8BB;"
                            Click="Close_Click" Width="34" Height="34" />
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

            <!-- Bar placement -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Settings_BarDisplay}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="PrimaryBarRadio"
                                 Grid.Column="0"
                                 GroupName="BarPlacement"
                                 IsChecked="True"
                                 Checked="BarPlacement_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_PrimaryOnly}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="AllBarsRadio"
                                 Grid.Column="1"
                                 GroupName="BarPlacement"
                                 Checked="BarPlacement_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_AllMonitors}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Window detection -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Settings_WindowDetection}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="DetectAllRadio"
                                 Grid.Column="0"
                                 GroupName="DetectionMode"
                                 IsChecked="True"
                                 Checked="DetectionMode_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_AllWindows}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="DetectSameScreenRadio"
                                 Grid.Column="1"
                                 GroupName="DetectionMode"
                                 Checked="DetectionMode_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_SameScreen}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Theme -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_Theme}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="ThemeSystemRadio"
                                 Grid.Column="0"
                                 GroupName="Theme"
                                 IsChecked="True"
                                 Checked="Theme_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_ThemeSystem}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="ThemeDarkRadio"
                                 Grid.Column="1"
                                 GroupName="Theme"
                                 Checked="Theme_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_ThemeDark}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="ThemeLightRadio"
                                 Grid.Column="2"
                                 GroupName="Theme"
                                 Checked="Theme_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_ThemeLight}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Opacity -->
            <StackPanel Grid.Row="3" Margin="0,0,0,16">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource Settings_BarOpacity}" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <TextBlock x:Name="OpacityValueText" Grid.Column="1" FontSize="11"
                               Foreground="{DynamicResource MutedTextBrush}" Text="100%" />
                </Grid>
                <Slider x:Name="OpacitySlider"
                        Minimum="30" Maximum="100" Value="100"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        ValueChanged="Opacity_Changed" />
            </StackPanel>

            <!-- Branding -->
            <StackPanel Grid.Row="4" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Settings_Branding}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="BrandingVisibleRadio"
                                 Grid.Column="0"
                                 GroupName="Branding"
                                 IsChecked="True"
                                 Checked="Branding_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_ShowLogo}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="BrandingHiddenRadio"
                                 Grid.Column="1"
                                 GroupName="Branding"
                                 Checked="Branding_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_HideLogo}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Tab Width -->
            <StackPanel Grid.Row="5" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Settings_TabWidth}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="TabFullWidthRadio"
                                 Grid.Column="0"
                                 GroupName="TabWidth"
                                 IsChecked="True"
                                 Checked="TabWidth_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_FullWidth}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="TabFixedWidthRadio"
                                 Grid.Column="1"
                                 GroupName="TabWidth"
                                 Checked="TabWidth_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_FixedWidth}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Language -->
            <StackPanel Grid.Row="6" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Settings_Language}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <ComboBox x:Name="LanguageCombo"
                          SelectionChanged="Language_Changed"
                          FontSize="11"
                          Height="28"
                          Padding="8,4" />
            </StackPanel>

            <!-- Accent Color -->
            <StackPanel Grid.Row="7" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_AccentColor}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <ComboBox x:Name="AccentColorCombo"
                          SelectionChanged="AccentColor_Changed"
                          FontSize="11"
                          Height="28"
                          Padding="8,4">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding Hex}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Bar Visibility -->
            <StackPanel Grid.Row="8" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_BarVisibility}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="BarAlwaysVisibleRadio"
                                 Grid.Column="0"
                                 GroupName="BarVisibility"
                                 IsChecked="True"
                                 Checked="BarVisibility_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_AlwaysVisible}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="BarAutoHideRadio"
                                 Grid.Column="1"
                                 GroupName="BarVisibility"
                                 Checked="BarVisibility_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_AutoHide}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Startup -->
            <StackPanel Grid.Row="9" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_Startup}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="StartupEnabledRadio"
                                 Grid.Column="0"
                                 GroupName="Startup"
                                 Checked="Startup_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_StartAtLogin}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="StartupDisabledRadio"
                                 Grid.Column="1"
                                 GroupName="Startup"
                                 IsChecked="True"
                                 Checked="Startup_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_DontStartAtLogin}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Clock -->
            <StackPanel Grid.Row="10" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_Clock}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="ClockVisibleRadio"
                                 Grid.Column="0"
                                 GroupName="Clock"
                                 IsChecked="True"
                                 Checked="Clock_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_ShowClock}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="ClockHiddenRadio"
                                 Grid.Column="1"
                                 GroupName="Clock"
                                 Checked="Clock_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_HideClock}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Bar Size -->
            <StackPanel Grid.Row="11" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_BarSize}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="BarSizeSmallRadio"
                                 Grid.Column="0"
                                 GroupName="BarSize"
                                 IsChecked="True"
                                 Checked="BarSize_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_BarSizeSmall}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="BarSizeMediumRadio"
                                 Grid.Column="1"
                                 GroupName="BarSize"
                                 Checked="BarSize_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_BarSizeMedium}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="BarSizeLargeRadio"
                                 Grid.Column="2"
                                 GroupName="BarSize"
                                 Checked="BarSize_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_BarSizeLarge}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Background Blur -->
            <StackPanel Grid.Row="12" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_Blur}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="BlurDisabledRadio"
                                 Grid.Column="0"
                                 GroupName="Blur"
                                 IsChecked="True"
                                 Checked="Blur_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_BlurDisable}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="BlurEnabledRadio"
                                 Grid.Column="1"
                                 GroupName="Blur"
                                 Checked="Blur_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_BlurEnable}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
            </StackPanel>

            <!-- Updates -->
            <StackPanel Grid.Row="13" Margin="0,0,0,12">
                <TextBlock Text="{DynamicResource Settings_Updates}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="AutoUpdatesEnabledRadio"
                                 Grid.Column="0"
                                 GroupName="AutoUpdates"
                                 IsChecked="True"
                                 Checked="AutoUpdates_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Margin="0,0,8,0">
                        <TextBlock Text="{DynamicResource Settings_AutoUpdatesEnable}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                    <RadioButton x:Name="AutoUpdatesDisabledRadio"
                                 Grid.Column="1"
                                 GroupName="AutoUpdates"
                                 Checked="AutoUpdates_Changed"
                                 Foreground="{DynamicResource PrimaryTextBrush}">
                        <TextBlock Text="{DynamicResource Settings_AutoUpdatesDisable}" FontSize="11"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </RadioButton>
                </Grid>
                <Button x:Name="CheckUpdatesNowButton"
                        Content="{DynamicResource Settings_CheckUpdatesNow}"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="CheckUpdatesNow_Click"
                        HorizontalAlignment="Stretch"
                        Padding="12,6" />
            </StackPanel>

            <!-- Done button -->
            <Button Grid.Row="15"
                    Content="{DynamicResource Settings_Done}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Click="Close_Click"
                    HorizontalAlignment="Right"
                    Padding="20,6" />
            </Grid>
        </Grid>
    </Border>
</Window>
