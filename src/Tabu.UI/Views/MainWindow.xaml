<Window x:Class="Tabu.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Tabu.UI.ViewModels"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        Title="Tabu"
        Icon="pack://application:,,,/Assets/tabu.ico"
        Height="36" Width="800"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Left="0" Top="0">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PrevTabCommand}" />
        <KeyBinding Gesture="Ctrl+1" Command="{Binding GoToTabCommand}" CommandParameter="1" />
        <KeyBinding Gesture="Ctrl+2" Command="{Binding GoToTabCommand}" CommandParameter="2" />
        <KeyBinding Gesture="Ctrl+3" Command="{Binding GoToTabCommand}" CommandParameter="3" />
        <KeyBinding Gesture="Ctrl+4" Command="{Binding GoToTabCommand}" CommandParameter="4" />
        <KeyBinding Gesture="Ctrl+5" Command="{Binding GoToTabCommand}" CommandParameter="5" />
        <KeyBinding Gesture="Ctrl+6" Command="{Binding GoToTabCommand}" CommandParameter="6" />
        <KeyBinding Gesture="Ctrl+7" Command="{Binding GoToTabCommand}" CommandParameter="7" />
        <KeyBinding Gesture="Ctrl+8" Command="{Binding GoToTabCommand}" CommandParameter="8" />
        <KeyBinding Gesture="Ctrl+9" Command="{Binding GoToTabCommand}" CommandParameter="9" />
    </Window.InputBindings>

    <!-- Main bar container -->
    <Grid x:Name="BarContainer" Height="36" VerticalAlignment="Top">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="BarTranslate" Y="0" />
        </Grid.RenderTransform>
        <!-- Background layer (opacity-controlled) -->
        <Border x:Name="BarBackground"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                Opacity="{Binding BarOpacity}"
                CornerRadius="0,0,8,8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.35" Color="Black" Direction="270" />
            </Border.Effect>
        </Border>

        <!-- Content layer (always fully opaque) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,25,0" VerticalAlignment="Center"
                        MouseLeftButtonDown="DragBar_MouseLeftButtonDown"
                        Visibility="{Binding ShowBranding, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="🐙" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBlock Text="Tabu" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Tabs -->
            <ItemsControl x:Name="TabsControl" Grid.Column="1" ItemsSource="{Binding Tabs}" Margin="0">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1">
                                        <b:Interaction.Behaviors>
                                            <b:FluidMoveBehavior AppliesTo="Children" Duration="0:0:0.12" Tag="DataContext">
                                                <b:FluidMoveBehavior.EaseX>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </b:FluidMoveBehavior.EaseX>
                                                <b:FluidMoveBehavior.EaseY>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </b:FluidMoveBehavior.EaseY>
                                            </b:FluidMoveBehavior>
                                        </b:Interaction.Behaviors>
                                    </UniformGrid>
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UseFixedTabWidth}" Value="True">
                                <Setter Property="ItemsPanel">
                                    <Setter.Value>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <b:Interaction.Behaviors>
                                                    <b:FluidMoveBehavior AppliesTo="Children" Duration="0:0:0.12" Tag="DataContext">
                                                        <b:FluidMoveBehavior.EaseX>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </b:FluidMoveBehavior.EaseX>
                                                        <b:FluidMoveBehavior.EaseY>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </b:FluidMoveBehavior.EaseY>
                                                    </b:FluidMoveBehavior>
                                                </b:Interaction.Behaviors>
                                            </StackPanel>
                                        </ItemsPanelTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TabViewModel}">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="6,4" Margin="4,4"
                                Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5"
                                MouseLeftButtonDown="Tab_MouseLeftButtonDown"
                                MouseMove="Tab_MouseMove"
                                MouseLeftButtonUp="Tab_MouseLeftButtonUp"
                                MouseDown="Tab_MouseDown"
                                Tag="{Binding}"
                                MinWidth="32">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                    <TranslateTransform X="0" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding Icon}" Width="16" Height="16"
                                       Margin="0,0,6,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding Icon, Converter={StaticResource NullToCollapsedConverter}}" />
                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <Button x:Name="CloseBtn" Grid.Column="2"
                                        Style="{DynamicResource TabCloseButtonStyle}"
                                        Click="TabClose_Click"
                                        Tag="{Binding}"
                                        Margin="4,0,0,0"
                                        Visibility="Hidden" />
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ActiveTabBackgroundBrush}" />
                                <Setter TargetName="TabBorder" Property="TextBlock.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <Trigger SourceName="TabBorder" Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <DataTrigger Binding="{Binding DataContext.UseFixedTabWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                <Setter TargetName="TabBorder" Property="Width" Value="200" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Clock -->
            <TextBlock x:Name="ClockText" Grid.Column="2"
                       Text="{Binding CurrentTime}"
                       FontSize="11"
                       FontWeight="Medium"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0,12,0"
                       Visibility="{Binding ShowClock, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!-- Settings button -->
            <Button x:Name="SettingsButton" Grid.Column="3"
                    Click="Settings_Click"
                    ToolTip="{DynamicResource MainBar_SettingsTooltip}"
                    Style="{DynamicResource TitleBarButtonStyle}"
                    Content="&#xE713;"
                    Width="36" Height="36" />

            <!-- Close button -->
            <Button x:Name="CloseButton" Grid.Column="4"
                    Style="{DynamicResource CloseWindowButtonStyle}"
                    Content="&#xE8BB;" Click="Close_Click"
                    ToolTip="{DynamicResource MainBar_CloseTooltip}"
                    Width="36" Height="36" />
        </Grid>
    </Grid>
</Window>
