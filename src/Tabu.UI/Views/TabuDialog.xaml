<Window x:Class="Tabu.UI.Views.TabuDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tabu"
        Icon="pack://application:,,,/Assets/tabu.ico"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border x:Name="DialogRoot"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="10"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <StackPanel>
            <!-- Header strip with accent glyph + title (drag handle) -->
            <Grid x:Name="HeaderGrid" Background="Transparent"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBadge" Grid.Column="0"
                        Width="36" Height="36" CornerRadius="10"
                        Background="{DynamicResource AccentBrush}"
                        Margin="20,18,12,0" VerticalAlignment="Top">
                    <TextBlock x:Name="IconGlyph"
                               Text="&#xE7BA;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="18"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="TitleText" Grid.Column="1"
                           Text="Tabu"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,18,0,0" />

                <!-- Close X -->
                <Button x:Name="CloseButton" Grid.Column="2"
                        Width="32" Height="32" Margin="0,14,14,0"
                        VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                <TextBlock x:Name="Glyph"
                                           Text="&#xE8BB;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}" />
                                    <Setter TargetName="Glyph" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Body text -->
            <TextBlock x:Name="MessageText"
                       Margin="20,8,20,24"
                       FontSize="13" LineHeight="20"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" />

            <!-- Footer actions -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="16,14">
                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right" />
            </Border>
        </StackPanel>
    </Border>
</Window>
