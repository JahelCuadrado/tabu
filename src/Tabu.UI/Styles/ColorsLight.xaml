<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="PrimaryBackgroundColor">#F0F0F4</Color>
    <Color x:Key="SecondaryBackgroundColor">#E4E4EA</Color>
    <Color x:Key="TertiaryBackgroundColor">#D6D6DE</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#6B4FA0</Color>
    <Color x:Key="AccentHoverColor">#7D62B5</Color>
    <Color x:Key="AccentPressedColor">#5A3F8A</Color>

    <!-- Text -->
    <Color x:Key="PrimaryTextColor">#2A2A3A</Color>
    <Color x:Key="SecondaryTextColor">#5A5A6E</Color>
    <Color x:Key="MutedTextColor">#7A7A90</Color>

    <!-- Status -->
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="DangerHoverColor">#FF6B5A</Color>
    <Color x:Key="SuccessColor">#2ECC71</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#C8C8D4</Color>
    <Color x:Key="BorderHoverColor">#B0B0C0</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackgroundColor}" />
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackgroundColor}" />
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="{StaticResource TertiaryBackgroundColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}" />

</ResourceDictionary>
