<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="PrimaryBackgroundColor">#1A1A2E</Color>
    <Color x:Key="SecondaryBackgroundColor">#16213E</Color>
    <Color x:Key="TertiaryBackgroundColor">#0F3460</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#533483</Color>
    <Color x:Key="AccentHoverColor">#6A42A0</Color>
    <Color x:Key="AccentPressedColor">#4A2D75</Color>

    <!-- Text -->
    <Color x:Key="PrimaryTextColor">#E8E8E8</Color>
    <Color x:Key="SecondaryTextColor">#A0A0B0</Color>
    <Color x:Key="MutedTextColor">#606078</Color>

    <!-- Status -->
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="DangerHoverColor">#FF6B5A</Color>
    <Color x:Key="SuccessColor">#2ECC71</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#2A2A4A</Color>
    <Color x:Key="BorderHoverColor">#3A3A5A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackgroundColor}" />
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackgroundColor}" />
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="{StaticResource TertiaryBackgroundColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{StaticResource BorderHoverColor}" />

</ResourceDictionary>
